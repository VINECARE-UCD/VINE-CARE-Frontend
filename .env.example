VITE_API_URL=http://your-ec2-ip-or-domain:8002/api

# VineCare Frontend — Environment Variables Template
# Copy this file to .env.local and fill in your actual API URLs

# ==========================================
# Backend Microservices API URLs
# ==========================================

# Phenology Service (Port 8002)
# Used for: Phenology tracking, vine growth stages, KPI data
VITE_API_URL=http://vine-care-alb-endpoint.eu-central-1.elb.amazonaws.com/phenology/api

# Data Collection Service (Port 8000)
# Used for: Drone image uploads, image retrieval, file processing
VITE_DATA_COLLECTION_URL=http://vine-care-alb-endpoint.eu-central-1.elb.amazonaws.com/data/api

# Notification Service (Port 8001)
# Used for: Alerts, recommendations, user notifications
VITE_NOTIFICATION_URL=http://vine-care-alb-endpoint.eu-central-1.elb.amazonaws.com/notifications/api

# ==========================================
# LOCAL DEVELOPMENT CONFIGURATION
# ==========================================
# Use these URLs when running backend services locally with Docker Compose
# Uncomment and use these instead of AWS ALB URLs for local development

# VITE_API_URL=http://localhost:8002/api
# VITE_DATA_COLLECTION_URL=http://localhost:8000/api
# VITE_NOTIFICATION_URL=http://localhost:8001/api

# ==========================================
# Application Configuration
# ==========================================

# Application display name
VITE_APP_NAME=VineCare

# Application version (for frontend display)
VITE_APP_VERSION=1.0.0

# ==========================================
# Optional: Advanced Configuration
# ==========================================

# API request timeout (in milliseconds)
# VITE_API_TIMEOUT=30000

# Enable debug logging in browser console
# VITE_DEBUG=false

# Authentication token storage key
# VITE_AUTH_TOKEN_KEY=vinecare_token

# Default language
# VITE_DEFAULT_LANGUAGE=en

# Default timezone
# VITE_DEFAULT_TIMEZONE=Europe/Dublin

# ==========================================
# DEPLOYMENT-SPECIFIC SETTINGS
# ==========================================

# AWS Region (for frontend-hosted static assets)
# VITE_AWS_REGION=eu-central-1

# S3 Bucket for serving assets (if using S3 static hosting)
# VITE_S3_BUCKET=vine-care-frontend-assets

# CloudFront distribution (if using CDN)
# VITE_CLOUDFRONT_DOMAIN=d123456.cloudfront.net

# ==========================================
# Feature Flags (Optional)
# ==========================================

# Enable/disable specific features during development
# VITE_ENABLE_PREDICTIONS=true
# VITE_ENABLE_NOTIFICATIONS=true
# VITE_ENABLE_DRONE_UPLOADS=true
# VITE_ENABLE_PHENOLOGY_TRACKING=true
# VITE_ENABLE_KPI_DASHBOARD=true
